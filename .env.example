# Public Environment Variables (accessible in browser, prefix with PUBLIC_)
PUBLIC_APP_URL=http://localhost:3000
PUBLIC_CAL_COM_NAMESPACE=codefred
PUBLIC_PLAUSIBLE_DOMAIN=codefred.dev
PUBLIC_POSTHOG_KEY=your_posthog_project_api_key
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Private Environment Variables (server-only, no PUBLIC_ prefix)

# Contact Form - Email Integration (Resend)
RESEND_API_KEY=your_resend_api_key_here
EMAIL_ADDRESS=your_email@gmail.com

# GitHub API (optional, for higher rate limits)
GITHUB_TOKEN=your_github_personal_access_token

# YouTube Data API
YOUTUBE_API_KEY=your_youtube_api_key_here

# Cal.com API (for availability widget)
CAL_COM_API_KEY=your_cal_com_api_key_here
